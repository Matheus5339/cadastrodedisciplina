{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/controle-disciplinas.db"
  },
  "Jwt": {
    "Issuer": "controle-disciplinas-ucp",
    "Audience": "controle-disciplinas-ucp-front",
    "AccessTokenMinutos": 15,
    "RefreshTokenDias": 7
  },
  "PasswordHash": {
    "MemoryCostKib": 65536,
    "TimeCost": 3,
    "Lanes": 2,
    "HashLength": 32
  },
  "CsvImport": {
    "Directory": "data",
    "FileNames": [ "disciplinas.csv", "discipolinas.csv", "disciplinas-ecomp-ucp.csv" ]
  },
  "AllowedOrigins": [ "http://localhost:5173" ],
  "Seed": {
    "DemoAluno": false
  }
}
